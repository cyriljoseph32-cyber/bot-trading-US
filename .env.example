# ─── Signal Bot US — variables d'environnement ────────────────────────────
# Copier en .env (local) et/ou renseigner dans Vercel → Settings → Env Vars.
# AUCUN secret ne doit être commité. .env est ignoré par git.

# ── Sécurité du dashboard (Phase 0) ───────────────────────────────────────
# Token protégeant /api/positions ET /api/chat (REQUIS : ces endpoints sont
# refusés tant qu'il est absent — /api/chat consomme la clé Anthropic).
# Génère une valeur longue et aléatoire, ex : openssl rand -hex 32
DASHBOARD_TOKEN=

# Protège /api/cron (Vercel Cron l'envoie automatiquement). Recommandé.
CRON_SECRET=

# ── Données marché & alertes ──────────────────────────────────────────────
# Alertes email via https://resend.com (gratuit pour démarrer)
RESEND_API_KEY=
ALERT_EMAIL=
EMAIL_FROM=onboarding@resend.dev
# true = email quotidien même sans signal
ALERT_ALWAYS=

# ── Courtier Alpaca (https://alpaca.markets) ──────────────────────────────
# Clés API. Par défaut = PAPER TRADING (argent fictif). Sûr.
ALPACA_KEY_ID=
ALPACA_SECRET_KEY=
# true = le bot passe les ordres lui-même (achat marché + stop attaché)
AUTOTRADE=
# true = COMPTE RÉEL. NE PAS activer avant des semaines de paper trading validé.
ALPACA_LIVE=

# ── Paramètres de risque (Phase 1 — moteur de risque) ─────────────────────
# Risque par trade en % du compte (borné 0.1–5). Défaut 1.
RISK_PCT=1
# Perte max du jour en % : au-delà, plus aucune NOUVELLE entrée (sorties OK). Défaut 3.
MAX_DAILY_LOSS_PCT=3
# Nombre max de positions simultanées. Défaut 5.
MAX_OPEN_POSITIONS=5
# Nombre max d'entrées par jour (anti-sur-trading). Défaut 3.
MAX_TRADES_PER_DAY=3
# Taille max d'une position en % du compte (anti-concentration). Défaut 20.
MAX_POSITION_PCT=20
# Exposition brute max (somme des positions) en % du compte (anti-corrélation). Défaut 70.
MAX_GROSS_EXPOSURE_PCT=70
# Plafond de slippage à l'achat : ordre limite = close × (1 + x%). Défaut 0.5.
MAX_ENTRY_SLIPPAGE_PCT=0.5
# Arrêt d'urgence : "true" = aucune nouvelle entrée (les sorties restent actives).
KILL_SWITCH=
# Capital de référence pour les emails sans Alpaca. Défaut 10000.
DEFAULT_CAPITAL=10000

# URL publique du site (lien "ouvrir le dashboard" dans l'email)
APP_URL=

# ── Base de données (Phase 0.4 — Supabase) ────────────────────────────────
# Renseignées à l'étape base de données / journal de trades.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Assistant conversationnel (/api/chat) ─────────────────────────────────
# Clé API Anthropic (https://console.anthropic.com). Requise pour l'assistant.
ANTHROPIC_API_KEY=
